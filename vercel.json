{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "engineer_connect-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "engineer_connect-app/build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "/engineer_connect-app/build/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/engineer_connect-app/build/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
