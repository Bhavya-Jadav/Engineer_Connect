{
  "version": 2,
  "builds": [
    {
      "src": "engineer_connect-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "engineer_connect-app/build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/users/login",
      "dest": "/api/users/login.js"
    },
    {
      "src": "/api/users/register",
      "dest": "/api/users/register.js"
    },
    {
      "src": "/api/problems",
      "dest": "/api/problems/index.js"
    },
    {
      "src": "/api/test",
      "dest": "/api/test.js"
    },
    {
      "src": "/api/hello",
      "dest": "/api/hello.js"
    },
    {
      "src": "/(.*)",
      "dest": "/engineer_connect-app/build/index.html"
    }
  ]
}
